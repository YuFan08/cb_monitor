# 二选一: 直接填写浏览器 Cookie, 或指向 Get cookies.txt 导出的 Netscape 文件。
CB_COOKIE=
CB_COOKIE_FILE=
# 可选: Cloudflare 验证后的 cf_clearance, 会覆盖 Cookie 文件中的同名值。
CB_CF_CLEARANCE=
CB_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0 Safari/537.36
CB_TIMEOUT_SECONDS=15
CB_RETRY_ATTEMPTS=3
# 可选: 强制 CLI 使用和 Chrome 相同节点的本地 HTTP/mixed 代理。
CB_PROXY_URL=
CB_MPV_PATH=mpv
CB_LOG_LEVEL=INFO
